{
  "info": {
    "name": "Project Bamart API",
    "description": "API Collection for Bamart project backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    { "key": "run_ts",        "value": "" },
    { "key": "token",         "value": "" },
    { "key": "category_id",   "value": "" },
    { "key": "new_category_id","value": "" },
    { "key": "item_id",       "value": "" },
    { "key": "new_item_id",   "value": "" },
    { "key": "cart_item_id",  "value": "" },
    { "key": "order_id",      "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('run_ts')) {",
          "  pm.collectionVariables.set('run_ts', Date.now());",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Seller\",\n  \"email\": \"seller_{{run_ts}}@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"SELLER\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('run_ts')) {",
                  "  pm.collectionVariables.set('run_ts', Date.now());",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response time is less than 1000ms', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller_{{run_ts}}@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response time is less than 1000ms', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });",
                  "pm.test('Token captured from Set-Cookie or body', function () {",
                  "  var setCookie = pm.response.headers.get('Set-Cookie');",
                  "  if (setCookie) {",
                  "    var match = setCookie.match(/token=([^;]+)/);",
                  "    if (match) {",
                  "      pm.collectionVariables.set('token', match[1]);",
                  "      console.log('Token set from Set-Cookie header');",
                  "      return;",
                  "    }",
                  "  }",
                  "  var json = pm.response.json();",
                  "  if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token set from response body');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login - Invalid Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
